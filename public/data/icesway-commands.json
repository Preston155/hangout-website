    {
      "id": "moderation",
      "label": "Moderation Commands",
      "icon": "🛡️",
      "description": "Staff tools for keeping the server clean.",
      "commands": [
        {
          "name": "ban",
          "type": "slash",
          "description": "Ban a member",
          "permission": "Ban Members",
          "options": [
            {
              "name": "target",
              "description": "@user or ID"
            },
            {
              "name": "reason",
              "description": "Reason"
            }
          ],
          "usage": "/ban target:<target> reason:<reason>"
        },
        {
          "name": "kick",
          "type": "slash",
          "description": "Kick a member",
          "permission": "Kick Members",
          "options": [
            {
              "name": "target",
              "description": "@user or ID"
            },
            {
              "name": "reason",
              "description": "Reason"
            }
          ],
          "usage": "/kick target:<target> reason:<reason>"
        },
        {
          "name": "lock",
          "type": "slash",
          "description": "Lock a text channel",
          "permission": "Manage Channels",
          "options": [
            {
              "name": "channel",
              "description": "Target channel"
            }
          ],
          "usage": "/lock channel:<channel>"
        },
        {
          "name": "purge",
          "type": "slash",
          "description": "Delete messages in this channel while skipping pinned messages.",
          "permission": "Manage Messages",
          "options": [
            {
              "name": "amount",
              "description": "Messages to delete. Old messages are supported."
            },
            {
              "name": "mode",
              "description": "Use old to target messages older than 14 days."
            }
          ],
          "usage": "/purge amount:<amount> mode:<mode>"
        },
        {
          "name": "removewarn",
          "type": "slash",
          "description": "Remove a warning by case ID",
          "permission": "Moderate Members",
          "options": [
            {
              "name": "case_id",
              "description": "Case ID"
            }
          ],
          "usage": "/removewarn case_id:<case_id>"
        },
        {
          "name": "slowmode",
          "type": "slash",
          "description": "Set slowmode in a channel",
          "permission": "Manage Channels",
          "options": [
            {
              "name": "seconds",
              "description": "0-21600"
            },
            {
              "name": "channel",
              "description": "Target channel"
            }
          ],
          "usage": "/slowmode seconds:<seconds> channel:<channel>"
        },
        {
          "name": "timeout",
          "type": "slash",
          "description": "Timeout a user",
          "permission": "Moderate Members",
          "options": [
            {
              "name": "target",
              "description": "@user or ID"
            },
            {
              "name": "duration",
              "description": "e.g. 10m, 1h"
            },
            {
              "name": "reason",
              "description": "Reason"
            }
          ],
          "usage": "/timeout target:<target> duration:<duration> reason:<reason>"
        },
        {
          "name": "unban",
          "type": "slash",
          "description": "Unban a user by ID",
          "permission": "Ban Members",
          "options": [
            {
              "name": "target",
              "description": "User ID"
            },
            {
              "name": "reason",
              "description": "Reason"
            }
          ],
          "usage": "/unban target:<target> reason:<reason>"
        },
        {
          "name": "unlock",
          "type": "slash",
          "description": "Unlock a text channel",
          "permission": "Manage Channels",
          "options": [
            {
              "name": "channel",
              "description": "Target channel"
            }
          ],
          "usage": "/unlock channel:<channel>"
        },
        {
          "name": "untimeout",
          "type": "slash",
          "description": "Remove timeout",
          "permission": "Moderate Members",
          "options": [
            {
              "name": "target",
              "description": "@user or ID"
            }
          ],
          "usage": "/untimeout target:<target>"
        },
        {
          "name": "warn",
          "type": "slash",
          "description": "Warn a member",
          "permission": "Moderate Members",
          "options": [
            {
              "name": "target",
              "description": "@user or ID"
            },
            {
              "name": "reason",
              "description": "Reason"
            }
          ],
          "usage": "/warn target:<target> reason:<reason>"
        },
        {
          "name": "warnings",
          "type": "slash",
          "description": "Show warnings for a user",
          "permission": "Moderate Members",
          "options": [
            {
              "name": "target",
              "description": "@user or ID"
            }
          ],
          "usage": "/warnings target:<target>"
        }
      ]
