# ER:LC CAD / MDT — copy to .env and fill in values

PORT=3847
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string

# MySQL / MariaDB (required)
# --- Local dev ---
# DB_HOST=127.0.0.1
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=erlc_cad

# --- Plesk (prestonhq.com) — use Connection info from your database panel ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=prestonh_database
DB_PASSWORD=your_plesk_db_password_here
DB_NAME=prestonh_database

# Discord OAuth (optional — leave blank to use dev login)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=https://prestonhq.com/auth/discord/callback

# Dev login (local only — set false on production)
DEV_LOGIN=true
DEV_LOGIN_PASSWORD=admin123

# Production Plesk example:
# NODE_ENV=production
# DEV_LOGIN=false
# SESSION_SECRET=long-random-string-here

# Server branding
SERVER_NAME=Liberty County CAD
SERVER_LOGO=
