# Veltrix command sync — copy to .env (never commit .env)

# Auto-sync before auto-publish builds (1 = on)
BOT3_AUTO_SYNC=1

# Poll bot source every 2 minutes when running sync:watch
BOT3_SYNC_INTERVAL_MS=120000

# --- Option A: SSH (your live bot on the server) ---
BOT3_SSH_HOST=172.82.64.171
BOT3_SSH_USER=root
BOT3_SSH_PASSWORD=
# BOT3_SSH_KEY_PATH=C:/Users/You/.ssh/id_rsa
BOT3_REMOTE_PATH=/root/bots/bot3

# --- Option B: Local bot folder (overrides SSH if path exists) ---
# BOT3_LOCAL_PATH=C:/dev/bot3
